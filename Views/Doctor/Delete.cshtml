    font-weight: bold;
    color: #555;
}

dd {
    margin-bottom: 10px;
    padding-left: 10px;
}

form {
    margin-top: 20px;
}

.btn-danger {
    background-color: #dc3545;
    color: #fff;
    border: none;
    padding: 10px 20px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 16px;
}

.btn-danger:hover {
    background-color: #c82333;
}

a {
    color: #007bff;
    text-decoration: none;
    margin-left: 10px;
    font-size: 16px;
}

