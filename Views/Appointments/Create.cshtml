@model Healthcare.Models.Appointment
<form asp-action="Create">
    <div class="form-group">
        <label for="PatientID">Pacient</label>
        <select asp-for="PatientID" asp-items="ViewBag.Patients" class="form-control"></select>
    </div>
    <div class="form-group">
        <label for="DoctorID">Zdravnik</label>
        <select asp-for="DoctorID" asp-items="ViewBag.Doctors" class="form-control"></select>
    </div>
    <div class="form-group">
        <label for="AppointmentDate">Datum termina</label>
        <input asp-for="AppointmentDate" class="form-control" type="datetime-local" />
    </div>
    <div class="form-group">
        <label for="Reason">Razlog</label>
        <input asp-for="Reason" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Shrani</button>
</form>
